# Copy this file to your deployment provider's Environment Variables panel.
# Never commit real secrets.

GITHUB_TOKEN=replace_with_github_fine_grained_token
CONNECTOR_API_KEY=replace_with_long_random_connector_key
DEFAULT_OWNER=focusnegotiuminc-creator
DEFAULT_REPO=improved-rotary-phone

# Optional: only needed for /vercel/deploy endpoint
VERCEL_TOKEN=replace_with_vercel_token
VERCEL_PROJECT_ID=replace_with_vercel_project_id
VERCEL_TEAM_ID=replace_with_vercel_team_id_if_needed
