{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Focus: Private Console API",
      "type": "shell",
      "command": "python",
      "args": [
        "${workspaceFolder}/FOCUS_MASTER_AI/api_server.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Focus: Test Suite",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "pytest",
        "-q",
        "${workspaceFolder}/tests",
        "-o",
        "cache_dir=${workspaceFolder}/.pytest_cache/vscode"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PYTHONDONTWRITEBYTECODE": "1"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Focus: Build Master Archive",
      "type": "shell",
      "command": "python",
      "args": [
        "${workspaceFolder}/scripts/build_master_archive.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Focus: Export Runtime Manifests",
      "type": "shell",
      "command": "python",
      "args": [
        "${workspaceFolder}/scripts/export_runtime_manifests.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Focus: Sync Archive To Cloudflare",
      "type": "shell",
      "command": "python",
      "args": [
        "${workspaceFolder}/scripts/sync_master_archive_to_cloudflare.py",
        "--archive-root",
        "C:/Users/reggi/OneDrive/Desktop/FOCUS_MASTER_MASTER_ARCHIVE/current",
        "--manifests-dir",
        "C:/Users/reggi/OneDrive/Desktop/FOCUS_MASTER_MASTER_ARCHIVE/current/docs/manifests",
        "--cloudflare-public-dir",
        "${workspaceFolder}/cloudflare/focus-mobile-workbench/public",
        "--dest-subdir",
        "archives",
        "--report-file",
        "${workspaceFolder}/docs/manifests/cloudflare_storage_sync_report.md",
        "--include-zip",
        "--zip-dir-name",
        "apps",
        "--zip-dir-name",
        "sites",
        "--zip-dir-name",
        "private_console",
        "--zip-dir-name",
        "engines",
        "--zip-dir-name",
        "integrations",
        "--zip-dir-name",
        "artifacts"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Flux: Public QA",
      "type": "shell",
      "command": "python",
      "args": [
        "${workspaceFolder}/marketing/fluxcrave/verify_flux_public.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
