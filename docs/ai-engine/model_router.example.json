{
  "router_name": "focus-private-ai-engine-router",
  "version": "0.1.0",
  "default_rules": {
    "never_log_secrets": true,
    "high_impact_actions_require_approval": true,
    "public_claims_require_source": true,
    "deploy_requires_tests_or_documented_exception": true
  },
  "model_lanes": [
    {
      "id": "frontier_reasoner",
      "provider": "openai_or_other_provider",
      "use_for": [
        "complex planning",
        "code implementation",
        "QA synthesis"
      ],
      "notes": "Provider policies apply."
    },
    {
      "id": "external_reviewer",
      "provider": "claude_or_other_reviewer",
      "use_for": [
        "critique",
        "copy review",
        "risk review"
      ],
      "notes": "Provider policies apply."
    },
    {
      "id": "local_private_model",
      "provider": "ollama_lmstudio_or_vllm",
      "use_for": [
        "private drafts",
        "uncensored brainstorming within lawful/owned context",
        "offline red-team critique"
      ],
      "notes": "Use local model licenses and business policy."
    },
    {
      "id": "deterministic_tools",
      "provider": "local_shell_tests_linters_scanners",
      "use_for": [
        "tests",
        "builds",
        "traffic snapshots",
        "security checks"
      ],
      "notes": "Evidence beats vibes."
    }
  ],
  "business_lanes": [
    "Focus Negotium Inc",
    "Focus Records LLC",
    "Royal Lee Construction Solutions LLC",
    "Flux & Crave",
    "The Focus Corporation",
    "Partner/client lanes"
  ],
  "risk_gates": {
    "low": [
      "draft copy",
      "local analysis",
      "design concepts",
      "non-public code edits"
    ],
    "medium": [
      "commits",
      "test data generation",
      "internal docs"
    ],
    "high": [
      "deploy",
      "send outreach",
      "public post",
      "legal/financial/property/medical claims",
      "payments",
      "credential changes",
      "customer data transmission"
    ]
  }
}