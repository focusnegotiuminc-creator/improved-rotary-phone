# Copy to .env (gitignored) for local development only.

# InfinityFree deployment credentials
INFINITYFREE_FTP_HOST=ftpupload.net
INFINITYFREE_FTP_USER=your_username
INFINITYFREE_FTP_PASS=your_password
INFINITYFREE_REMOTE_DIR=htdocs
INFINITYFREE_STRICT=0

# Optional Replit deployment webhook/hook
REPLIT_DEPLOY_HOOK_URL=
REPLIT_DEPLOY_TOKEN=
REPLIT_DEPLOY_METHOD=POST
REPLIT_DEPLOY_TIMEOUT=30

# Live verification URL
FOCUS_APP_URL=https://thefocuscorp.com
FOCUS_APP_PATHS=/,/wp-admin,/ebooks/index.html,/landing.html
FOCUS_REQUIRE_ALL_PATHS=1
FOCUS_SKIP_TLS_VERIFY=1
